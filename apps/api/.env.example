# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://growease.vercel.app

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_BATCH_SIZE=25
AI_MAX_RETRIES=3

# Google Drive (scope: drive.file)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:4000/api/integrations/google-drive/callback

# Microsoft (Outlook + OneDrive)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_OUTLOOK_REDIRECT_URI=http://localhost:4000/api/integrations/outlook/callback
MICROSOFT_ONEDRIVE_REDIRECT_URI=http://localhost:4000/api/integrations/onedrive/callback

# Security (TOKEN_ENCRYPTION_KEY must be 32+ bytes; use: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=
REQUEST_ID_HEADER=x-request-id

# Limits
MAX_UPLOAD_BYTES=5242880
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
