{
  "name": "crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:turbo": "DEV_TURBOPACK=1 node scripts/dev.mjs",
    "dev:webpack": "next dev",
    "dev:stable": "rm -rf .next node_modules/.cache && next build && next start",
    "dev:clean": "rm -rf .next node_modules/.cache && node scripts/dev.mjs",
    "dev:reset": "rm -rf .next node_modules/.cache && node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "build:docker": "DOCKER_BUILD=1 next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "^15.5.20",
    "openai": "^6.45.0",
    "papaparse": "^5.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.20",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
